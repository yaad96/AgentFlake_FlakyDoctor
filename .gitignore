# FlakyDoctor runtime artifacts — cloned subject projects and per-run outputs
FlakyDoctor/projects/
FlakyDoctor/outputs/
FlakyDoctor/install_*.csv

# Untracked Anthropic API key — holds the secret key, never commit
.anthropic_api_key

# Python bytecode caches — auto-generated, must never be committed
__pycache__/
*.pyc
*.pyo
*.pyd

# macOS Finder metadata — purely Finder UI state, no code value
.DS_Store

# Claude Code session state — local-only, must not be committed
.claude/
